<html>
  <body style='font-family: sans-serif; max-width: 600px; margin: auto;'>
    <h2>You've been added to a Selection</h2>
    <p>Hi {{firstName}},</p>
    <p>
      <strong>{{inviterName}}</strong>
      has added you to the selection
      <strong>"{{selectionName}}"</strong>
      as a
      <strong>{{role}}</strong>.
    </p>
    <p>
      <a
        href='{{selectionUrl}}'
        style='background:#4F46E5;color:white;padding:10px 20px;border-radius:6px;text-decoration:none;'
      >
        View Selection
      </a>
    </p>
    <p style='color:#888; font-size:12px;'>If you believe this is a mistake,
      please contact support.</p>
  </body>
</html>